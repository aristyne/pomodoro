{
  "name": "pomodoro-desktop",
  "version": "0.1.0",
  "description": "Desktop Pomodoro Timer for Students - Electron",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64",
    "dist": "npm run dist:win"
  },
  "build": {
    "appId": "com.yourdomain.pomodoro-desktop",
    "productName": "Pomodoro Timer",
    "files": [
      "**/*"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^25.3.0",
    "electron-builder": "^26.0.0"
  }
}
